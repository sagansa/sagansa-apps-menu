# API mobile endpoint used by the public menu frontend.
NEXT_PUBLIC_API_BASE_URL=https://api-mobile.sagansa.id/api

# Public URL that serves product images (image service / img.sagansa.id).
NEXT_PUBLIC_STORAGE_BASE_URL=https://img.sagansa.id/storage

NEXT_PUBLIC_APP_NAME="Menu Sagansa"
NEXT_PUBLIC_APP_DESCRIPTION="Customer ordering system for SAGANSA platform"

# SEO & Site URL (used for canonical, OG tags, sitemap, robots, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://menu.sagansa.id
