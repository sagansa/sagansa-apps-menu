# API mobile endpoint used by the public menu frontend.
NEXT_PUBLIC_API_BASE_URL=https://api-mobile.sagansa.id/api

# Public URL that serves files from services/api-mobile FILESYSTEM_PUBLIC_ROOT.
# Must match the Laravel FILESYSTEM_PUBLIC_URL value if that URL is publicly reachable.
NEXT_PUBLIC_STORAGE_BASE_URL=https://mobile.sagansa.id/storage

NEXT_PUBLIC_APP_NAME="Menu Sagansa"
NEXT_PUBLIC_APP_DESCRIPTION="Customer ordering system for SAGANSA platform"
